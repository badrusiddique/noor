GoogleService-Info.plist

# Build pipeline cache
data/cache/
data/manifest.json

# Supply chain
sbom.json
sbom.xml

# Sentry
.sentryclirc

# Build-time generated DB (Phase 1 will populate; Phase 0 keeps placeholder dir)
assets/db/quran.db
assets/db/quran.db-*

# Audio bundle (Phase 1 will populate)
assets/audio/*.mp3
assets/audio/Alafasy/*.mp3
assets/audio/**/*.mp3

# Font bundle (Phase 1b will populate)
# Fonts are downloaded by `pnpm fonts:fetch` from pinned mirrors and verified
# against data/manifest.json -- they are reproducible, large, and license-flagged,
# so we never commit them.
assets/fonts/*.ttf
assets/fonts/*.otf
assets/fonts/*.woff
assets/fonts/*.woff2

# Maestro
.maestro/.cache/

# Misc
*.log
*.tsbuildinfo

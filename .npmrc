# pnpm + React Native + Expo strict-mode reconciliation.
#
# Metro resolves transpiled `require('@babel/runtime/helpers/...')` calls
# at the project root, and many React Native modules expect their peer
# deps (react, react-native, @babel/runtime) to be flat-installed. pnpm's
# default strict node_modules layout hides transitive deps from the root,
# which breaks Metro's resolution at bundle time on web (and occasionally
# on native, e.g. when a community module ships pre-transpiled JS).
#
# Public-hoist-pattern surfaces the matched packages to the top-level
# `node_modules/` while keeping pnpm's strict guarantees for the rest of
# the dependency graph. Keep this list narrow — every entry is a hoist
# we have a concrete reason for.
public-hoist-pattern[]=*@babel/runtime*
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=*@react-native*
public-hoist-pattern[]=*expo-*
# ESLint flat config in `eslint.config.mjs` imports `@eslint/eslintrc` to
# bridge legacy `eslint-config-expo` extends; that package is a transitive
# of `eslint` itself and pnpm's strict layout otherwise hides it.
public-hoist-pattern[]=*eslint*

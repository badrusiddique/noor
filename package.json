{
  "name": "noor",
  "version": "0.3.0",
  "private": true,
  "description": "Noor — a South Asian Quran reading app for iOS and Android. Privacy-first, no backend, single TypeScript codebase via Expo + React Native.",
  "author": "Badrudduza Siddique",
  "license": "MIT",
  "homepage": "https://github.com/badrusiddique/noor",
  "repository": {
    "type": "git",
    "url": "https://github.com/badrusiddique/noor"
  },
  "bugs": {
    "url": "https://github.com/badrusiddique/noor/issues"
  },
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "db:build": "tsx scripts/build-db.ts",
    "db:verify": "tsx scripts/verify-db.ts",
    "audio:bundle": "tsx scripts/bundle-audio.ts",
    "fonts:fetch": "tsx scripts/fetch-fonts.ts",
    "db:render-assert": "tsx scripts/render-assert.ts",
    "knip": "knip",
    "madge": "madge --circular --extensions ts,tsx src app",
    "size": "size-limit",
    "prepare": "husky",
    "doctor": "expo-doctor"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@gorhom/bottom-sheet": "^5.0.6",
    "@op-engineering/op-sqlite": "^11.0.0",
    "@react-native-community/netinfo": "11.5.2",
    "@sentry/react-native": "^6.4.0",
    "@shopify/flash-list": "1.8.3",
    "expo": "~52.0.0",
    "expo-asset": "~11.1.7",
    "expo-constants": "~17.1.8",
    "expo-dev-client": "~5.2.4",
    "expo-file-system": "~18.1.11",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-keep-awake": "~14.1.4",
    "expo-linking": "~7.1.7",
    "expo-localization": "~16.1.6",
    "expo-router": "~4.0.9",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-system-ui": "~4.0.4",
    "expo-updates": "~0.28.18",
    "i18n-js": "^4.5.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.85.2",
    "react-native-exception-handler": "^2.10.10",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-mmkv": "^3.2.0",
    "react-native-pager-view": "6.9.1",
    "react-native-reanimated": "~3.19.5",
    "react-native-safe-area-context": "4.14.1",
    "react-native-screens": "~4.24.0",
    "react-native-svg": "15.15.4",
    "react-native-track-player": "^4.1.1",
    "react-native-web": "~0.21.2",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@size-limit/preset-app": "^11.1.6",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.8.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.10",
    "@types/react": "~18.3.12",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "better-sqlite3": "^11.5.0",
    "eslint": "^9.14.0",
    "eslint-config-expo": "~8.0.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-native": "^4.1.0",
    "expo-doctor": "^1.12.5",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "knip": "^5.40.0",
    "lint-staged": "^15.2.10",
    "madge": "^8.0.0",
    "node-fetch": "^3.3.2",
    "prettier": "^3.3.3",
    "size-limit": "^11.1.6",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "xml2js": "^0.6.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.14.4",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "size-limit": [
    {
      "path": "dist/**/*.js",
      "limit": "50 mb",
      "name": "Total bundle"
    }
  ]
}
